# Bansari Commerce — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ============================================================
# SUPABASE
# ============================================================

# Your Supabase project URL (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe to expose — protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key (SERVER ONLY — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================================
# RAZORPAY
# ============================================================

# Razorpay API Key ID (use test key for dev: rzp_test_...)
RAZORPAY_KEY_ID=rzp_test_your_key_id

# Razorpay API Key Secret (SERVER ONLY)
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Razorpay Webhook Secret — set this in Razorpay Dashboard → Webhooks (SERVER ONLY)
# Generate with: openssl rand -hex 32
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ============================================================
# EMAIL (RESEND)
# ============================================================

# Resend API Key (SERVER ONLY)
RESEND_API_KEY=re_your_resend_api_key

# Verified sender email address
EMAIL_FROM=orders@yourdomain.com

# ============================================================
# APPLICATION
# ============================================================

# Full production URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://bansaricollections.com
