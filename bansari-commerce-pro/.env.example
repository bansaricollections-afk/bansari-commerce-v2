# =============================================================================
# Bansari Commerce — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file containing real secrets.
#
# For Vercel deployment, add every variable in:
#   Vercel Dashboard → Project → Settings → Environment Variables
# See ENVIRONMENT.md for full setup instructions.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Found in: Supabase Dashboard → Project Settings → API

# Public anon key — safe to expose to the browser.
# Used by the client-side Supabase SDK.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service-role key — NEVER expose to the browser or commit to git.
# Used exclusively by server-side API routes to bypass RLS for trusted writes.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Razorpay
# -----------------------------------------------------------------------------
# Found in: Razorpay Dashboard → Settings → API Keys

# Public key ID — safe to expose to the browser (used to load Razorpay.js).
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Secret key — NEVER expose to the browser.
# Used server-side to:
#   1. Create Razorpay orders (/api/orders/create-order)
#   2. Verify payment HMAC signatures (/api/orders/create)
#   3. Fetch payment details for webhook recovery (/api/webhook)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Webhook secret — set in Razorpay Dashboard → Webhooks → your endpoint → Secret.
# Used to verify Razorpay webhook deliveries via HMAC-SHA256 over the raw body.
# Different from RAZORPAY_KEY_SECRET — this is a dedicated webhook signing secret.
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# -----------------------------------------------------------------------------
# Resend (transactional email)
# -----------------------------------------------------------------------------
# Found in: Resend Dashboard → API Keys
# Requires a verified sending domain configured in Resend.

RESEND_API_KEY=re_xxxxxxxxxxxx

# The verified From address used for all outbound emails.
# Must match a domain verified in your Resend account.
RESEND_FROM_EMAIL=orders@bansaricollections.com

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
# Public canonical URL of the site — no trailing slash.
# Used by robots.ts, sitemap.ts, og-image metadata, and email templates.

NEXT_PUBLIC_SITE_URL=https://bansaricollections.com

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
# Admin routes are protected by middleware (src/middleware.ts).
# The admin user must have app_metadata.role = 'admin' set in Supabase Auth.
# No env var is required for this — role is enforced by the middleware
# reading the Supabase session server-side.
#
# To grant admin access to a user:
#   Supabase Dashboard → Authentication → Users → [user] → Edit → app_metadata:
#   { "role": "admin" }

# -----------------------------------------------------------------------------
# Optional: Next.js
# -----------------------------------------------------------------------------
# Uncomment if you need to configure a custom Next.js base URL for local dev.
# NEXTAUTH_URL=http://localhost:3000
